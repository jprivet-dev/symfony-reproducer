{% extends 'base.html.twig' %}

{% block title %}PDF Debug{% endblock %}

{% block body %}
    <div class="container-fluid px-4 py-5">
        <h1 class="mb-5">PDF Debug</h1>

        {% for result in results %}
            <div class="mb-5">
                <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-4">
                    <strong>Page {{ result.pageNumber }}</strong>

                    {% if result.missingReference %}
                        <span class="badge text-bg-warning">
                        ⚠ Missing reference — run bin/console app:pdf:generate
                    </span>
                    {% elseif result.hasPassed() %}
                        <span class="badge text-bg-success">✓ Pass</span>
                    {% else %}
                        <span class="badge text-bg-danger">
                        ✗ Fail — distortion: {{ result.distortion|number_format(6) }}
                    </span>
                    {% endif %}
                </div>

                <div class="row g-4">
                    <div class="col-4">
                        <p class="text-center text-muted text-uppercase small fw-bold mb-2">Actual</p>
                        <img src="{{ path('app_pdf_debug_image', { type: 'actual', page: result.pageNumber }) }}"
                             class="img-fluid border w-100">
                    </div>

                    <div class="col-4">
                        <p class="text-center text-muted text-uppercase small fw-bold mb-2">Reference</p>
                        {% if result.missingReference %}
                            <div class="border border-dashed d-flex align-items-center justify-content-center text-muted small"
                                 style="min-height: 200px;">
                                No reference file yet.
                            </div>
                        {% else %}
                            <img src="{{ path('app_pdf_debug_image', { type: 'reference', page: result.pageNumber }) }}"
                                 class="img-fluid border w-100">
                        {% endif %}
                    </div>

                    <div class="col-4">
                        <p class="text-center text-muted text-uppercase small fw-bold mb-2">Diff</p>
                        {% if result.missingReference %}
                            <div class="border border-dashed d-flex align-items-center justify-content-center text-muted small"
                                 style="min-height: 200px;">
                                No diff available.
                            </div>
                        {% else %}
                            <img src="{{ path('app_pdf_debug_image', { type: 'diff', page: result.pageNumber }) }}"
                                 class="img-fluid border w-100">
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
