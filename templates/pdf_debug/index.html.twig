<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>PDF Debug</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: monospace;
            padding: 2rem;
            background: #1a1a1a;
            color: #eee;
        }

        h1 {
            margin-bottom: 2rem;
        }

        .page {
            margin-bottom: 3rem;
        }

        .page-title {
            display: flex;
            align-items: center;
            gap: 1rem;
            border-bottom: 1px solid #444;
            padding-bottom: 0.75rem;
            margin-bottom: 1rem;
        }

        .columns {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1rem;
        }

        .column h3 {
            text-align: center;
            margin-bottom: 0.5rem;
            font-size: 0.85rem;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .column img {
            width: 100%;
            border: 1px solid #333;
            display: block;
        }

        .missing {
            color: #f90;
            font-size: 0.9rem;
        }

        .badge-pass {
            background: #1a3a1a;
            color: #4c4;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.85rem;
        }

        .badge-fail {
            background: #3a1a1a;
            color: #f44;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.85rem;
        }

        .badge-missing {
            background: #3a2a00;
            color: #f90;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.85rem;
        }

        .no-image {
            background: #222;
            border: 1px dashed #444;
            padding: 2rem;
            text-align: center;
            color: #666;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
<h1>PDF Debug</h1>

{% for result in results %}
    <div class="page">
        <div class="page-title">
            <strong>Page {{ result.pageNumber }}</strong>

            {% if result.missingReference %}
                <span class="badge-missing">⚠ Missing reference — run bin/console app:pdf:generate</span>
            {% elseif result.hasPassed() %}
                <span class="badge-pass">✓ Pass</span>
            {% else %}
                <span class="badge-fail">✗ Fail — distortion: {{ result.distortion|number_format(6) }}</span>
            {% endif %}
        </div>

        <div class="columns">
            <div class="column">
                <h3>Actual</h3>
                <img src="{{ path('app_pdf_debug_image', { type: 'actual', page: result.pageNumber }) }}">
            </div>

            <div class="column">
                <h3>Reference</h3>
                {% if result.missingReference %}
                    <div class="no-image">No reference file yet.</div>
                {% else %}
                    <img src="{{ path('app_pdf_debug_image', { type: 'reference', page: result.pageNumber }) }}">
                {% endif %}
            </div>

            <div class="column">
                <h3>Diff</h3>
                {% if result.missingReference %}
                    <div class="no-image">No diff available.</div>
                {% else %}
                    <img src="{{ path('app_pdf_debug_image', { type: 'diff', page: result.pageNumber }) }}">
                {% endif %}
            </div>
        </div>
    </div>
{% endfor %}
</body>
</html>
