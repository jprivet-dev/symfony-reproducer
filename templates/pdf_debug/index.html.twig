<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>PDF Debug</title>
    <style>
        body {
            font-family: monospace;
            padding: 2rem;
            background: #1a1a1a;
            color: #eee;
        }

        h1 {
            color: #fff;
        }

        .page {
            margin-bottom: 3rem;
        }

        .page h2 {
            border-bottom: 1px solid #444;
            padding-bottom: 0.5rem;
        }

        .columns {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1rem;
        }

        .column h3 {
            text-align: center;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            color: #aaa;
        }

        .column img {
            width: 100%;
            border: 1px solid #444;
        }

        .missing {
            color: #f90;
        }

        .pass {
            color: #4c4;
        }

        .fail {
            color: #f44;
        }

        .distortion {
            text-align: center;
            margin-top: 0.5rem;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
<h1>PDF Debug</h1>

{% for result in results %}
    <div class="page">
        <h2>
            Page {{ result.pageNumber }} —
            {% if result.missingReference %}
                <span class="missing">⚠ Missing reference</span>
            {% elseif result.hasPassed() %}
                <span class="pass">✓ Pass</span>
            {% else %}
                <span class="fail">✗ Fail (distortion: {{ result.distortion|number_format(6) }})</span>
            {% endif %}
        </h2>

        <div class="columns">
            <div class="column">
                <h3>Actual</h3>
                <img src="data:image/png;base64,{{ result.actualPath|file_get_contents|base64_encode }}">
            </div>

            <div class="column">
                <h3>Reference</h3>
                {% if result.referencePath %}
                    <img src="data:image/png;base64,{{ result.referencePath|file_get_contents|base64_encode }}">
                {% else %}
                    <p class="missing">No reference file yet.<br>Run: <code>bin/console app:pdf:generate</code></p>
                {% endif %}
            </div>

            <div class="column">
                <h3>Diff</h3>
                {% if result.diffPath %}
                    <img src="data:image/png;base64,{{ result.diffPath|file_get_contents|base64_encode }}">
                {% else %}
                    <p class="missing">No diff available.</p>
                {% endif %}
            </div>
        </div>
    </div>
{% endfor %}
</body>
</html>
