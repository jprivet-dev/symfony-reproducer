<!DOCTYPE html>
<html>
<body>
{{ form_start(form) }}
{{ form_row(form.username) }}
<button type="submit">Create User</button>
{{ form_end(form) }}

{% if form.vars.errors|length > 0 %}
    <ul>
        {% for error in form.vars.errors %}
            <li style="color:red">{{ error.message }}</li>
        {% endfor %}
    </ul>
{% endif %}
</body>
</html>
